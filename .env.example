# Copy to .env and customize (loaded by Makefile via -include .env)
# Remotes are also loaded from context/madmail/.env when present.

# Admin UI (git submodule: external/madmail-admin-web)
# ADMIN_WEB_DIR=external/madmail-admin-web

# Local state (see data/chatmail.toml)
# STATE_DIR=./data
# CONFIG=./data/chatmail.toml

# relay-ping dclogin test (two dclogin: URIs from http://127.0.0.1:8080/new)
# DCLOGIN1=dclogin:alice@[127.0.0.1]/?p=...&ih=127.0.0.1&ip=1143&is=plain&sh=127.0.0.1&sp=2525&ss=plain
# DCLOGIN2=dclogin:bob@[127.0.0.1]/?p=...&ih=127.0.0.1&ip=1143&is=plain&sh=127.0.0.1&sp=2525&ss=plain
# RELAY_TIMEOUT=3m
# RELAY_STEP_TIMEOUT=45s
